# Copy to .env and fill in values: cp .env.example .env

# --- X API (app token for scheduled fetches) ---
# Developer Console → your app → Keys and tokens
X_BEARER_TOKEN=

# --- Database ---
# Shared across git worktrees; set a stable path on the VPS.
# Default when unset: ~/.local/share/newsletter-tool/newsletter.db
# DATABASE_PATH=~/.local/share/newsletter-tool/newsletter.db

# --- X OAuth (sign in with X in the browser) ---
# Developer Console → your app → User authentication settings
# Callback URL must match EXACTLY what you registered (scheme, host, path).
# Local:
X_OAUTH_CALLBACK_URL=http://127.0.0.1:8000/auth/callback
# Production (apex domain — no subdomain required):
# X_OAUTH_CALLBACK_URL=https://morementallystablexexperience.com/auth/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# Signs the browser session cookie (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Stripe (hosted Checkout: $1 entry + budget top-ups) ---
# Dashboard → Developers → API keys → Secret key (sk_test_... while testing, sk_live_... in production)
STRIPE_SECRET_KEY=

# Dashboard → Developers → Webhooks → your endpoint → Signing secret (whsec_...)
# Stripe sends payment notifications to POST /billing/webhook on your server; this secret proves the message really came from Stripe.
STRIPE_WEBHOOK_SECRET=

# Public URL where users open the site in a browser (used for Stripe success/cancel redirects).
# Not a subdomain — just your real domain. Local dev:
APP_BASE_URL=http://127.0.0.1:8000
# Production:
# APP_BASE_URL=https://morementallystablexexperience.com
