# Copy to .env and fill in values: cp .env.example .env
# X API v2 bearer token (Developer Console → your app → Keys and tokens)
X_BEARER_TOKEN=

# SQLite database file (shared across git worktrees; override on VPS if needed)
# Default when unset: ~/.local/share/newsletter-tool/newsletter.db
# DATABASE_PATH=~/.local/share/newsletter-tool/newsletter.db

# X OAuth 2.0 user authentication (Developer Console → your app → User authentication settings)
# Callback URL must match exactly what you registered (e.g. http://127.0.0.1:8000/auth/callback locally)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_CALLBACK_URL=http://127.0.0.1:8000/auth/callback

# Signs the browser session cookie; use a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Stripe (hosted Checkout — entry $1 API budget + top-ups)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_BASE_URL=http://127.0.0.1:8000
